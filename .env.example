# Copy this file to .env and fill in your values.
# All variables are required — the service will not start if any are missing.

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Tavily search API key (https://app.tavily.com)
TAVILY_API_KEY=tvly-your-key-here

# Contexter service URL
CONTEXTER_URL=http://localhost:8001

# Absolute path to the workspace directory mounted into the container
WORKSPACE_ROOT=/workspace

# Main agent LLM (must be an OpenRouter model slug)
LLM_MODEL=anthropic/claude-sonnet-4-5

# Morph applier model (OpenRouter slug)
APPLIER_MODEL=morph/morph-v3-fast

# Small/cheap LLM used for context extraction before applying edits
EXTRACTOR_MODEL=qwen/qwen3-8b

# LLM sampling temperature (0.0 = deterministic)
LLM_TEMPERATURE=0.0

# OpenRouter base URL (rarely needs changing)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
